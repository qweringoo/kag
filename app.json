{
  "expo": {
    "name": "かぐ",
    "slug": "kag",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.qweringo.kag"
    },
    "android": {
      "bundleIdentifier": "com.qweringo.kag",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-media-library",
        {
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "このアプリでは、写真を撮るためにカメラへのアクセスが必要です。"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "このアプリでは、写真に位置情報を付与するために位置情報へのアクセスが必要です。",
          "locationWhenInUsePermission": "このアプリでは、写真に位置情報を付与するために位置情報へのアクセスが必要です。"
        }
      ]
    ],
    "scheme": "qweringo-kag"
  }
}